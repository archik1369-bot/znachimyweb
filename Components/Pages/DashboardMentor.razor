@rendermode InteractiveServer
@page "/dashboard-mentor"

<PageTitle>MentoRate — Кабинет Наставника</PageTitle>

<div class="mentor-container">

    @* ВЕРХНЯЯ ПАНЕЛЬ *@
    <header class="mentor-header border-box">
        <div class="user-id">
            ID: 541 | <b>Пользователь:</b> Иванов П.С. (Старший наставник)
        </div>
        <a href="/" class="btn-logout">Выйти</a>
    </header>

    @* ДВУХКОЛОНОЧНАЯ СЕТКА *@
    <div class="mentor-grid">

        @* ЛЕВАЯ КОЛОНКА *@
        <aside class="left-col">
            <div class="border-box mb-20">
                <h5 class="col-title">Мои подопечные (Лимит 3)</h5>
                <div class="border-box mb-20">
                    <h5 class="col-title">Мои подопечные (Лимит 3)</h5>
                    <div class="student-list">
                        @foreach (var student in Students)
                        {
                            <div class="student-item @(student.Id == selectedStudentId ? "active" : "text-muted")"
                                 @onclick="() => SelectStudent(student.Id)">
                                <span class="student-name">@student.Name @(student.Id == selectedStudentId ? "[ВЫБРАН]" : "")</span>
                                <span class="student-progress">Прогресс МЛ: @student.Progress%</span>
                            </div>
                        }
                    </div>
                </div>

            </div>

            <div class="border-box">
                <h5 class="col-title"> ОБЩИЙ ЗАЧЕТ НАСТАВНИКОВ</h5>
                <p class="score-text">Мои баллы за квартал: <b>340 очков</b></p>
            </div>
        </aside>

        @* ПРАВАЯ КОЛОНКА *@
        <main class="right-col border-box">
            <div class="ml-header">
                <h4> Маршрутный лист (@GetSelectedStudentName())</h4>
                <div class="ml-actions">
                    <button class="btn-black">Редактировать МЛ</button>
                    <button class="btn-outline">Выгрузить в PDF</button>
                </div>
            </div>
            <!-- --- БЛОК СТАРТ. МОЯ ЦЕЛЬ НА КВАРТАЛ --- -->
            <div class="start-block">
                <h5 class="start-title">СТАРТ. МОЯ ЦЕЛЬ НА КВАРТАЛ</h5>
                <p class="start-subtitle">Что подросток хочет попробовать за эти 3 месяца? (Выберите 1-3 пункта):</p>

                <div class="start-checkbox-group">
                    <label class="start-check-label">
                        <input type="checkbox" checked /> Найти дело, которое мне нравится
                    </label>
                    <label class="start-check-label">
                        <input type="checkbox" /> Перестать срываться на конфликты
                    </label>
                    <label class="start-check-label">
                        <input type="checkbox" checked /> Найти компанию, где меня не будут давить
                    </label>
                    <label class="start-check-label">
                        <input type="checkbox" /> Попробовать заработать или помочь другим
                    </label>
                    <label class="start-check-label">
                        <input type="checkbox" @bind="isCustomGoalChecked" /> Своё:
                        <input type="text" class="custom-goal-input" placeholder="Впишите индивидуальную цель..." @bind="customGoalText" disabled="@(!isCustomGoalChecked)" />
                    </label>

                </div>

                <div class="start-input-group">
                    <label class="start-input-label">Стартовая точка (честно сам(а) себе):</label>
                    <input type="text" class="start-form-input" placeholder="Введите текущее состояние подростка..." value="Апатия, ничего не хочется делать в свободное время." />
                </div>

                <div class="start-input-group">
                    <label class="start-input-label">Сейчас я чувствую, что моя главная проблема —</label>
                    <input type="text" class="start-form-input" placeholder="В чем главная сложность..." value="Нет компании и увлечений, которые бы зажигали." />
                </div>
            </div>


            @* --- БЛОК: УРОВЕНЬ 1. Я ДЛЯ СЕБЯ --- *@
            <div class="ml-section mt-30">
                <h5 class="section-title">УРОВЕНЬ 1. Я ДЛЯ СЕБЯ (МОЕ РАЗВИТИЕ)</h5>
                <p class="section-subtitle">Проектирование шагов: что пробуем, как реализуем и сколько баллов за это даем.</p>

                <table class="ml-table">
                    <thead>
                        <tr>
                            <th style="width: 35%">Что планируем (мероприятие/действие)</th>
                            <th style="width: 35%">Как осуществляем (первый шаг)</th>
                            <th style="width: 15%">Дата выполнения</th>
                            <th style="width: 15%">Баллы</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var act in Level1Activities)
                        {
                            <tr>
                                <td>
                                    <input type="text" @bind="act.What" class="table-input" placeholder="Например: Секция самбо" />
                                </td>
                                <td>
                                    <input type="text" @bind="act.How" class="table-input" placeholder="Например: Сходить на пробную тренировку" />
                                </td>
                                <td>
                                    <input type="text"
                                           @bind="act.Date"
                                           class="table-input date-input"
                                           placeholder="ДД.ММ.ГГГГ"
                                           maxlength="10"
                                           pattern="\d{2}\.\d{2}\.\d{4}"
                                           title="Введите дату в формате ДД.ММ.ГГГГ (например, 13.06.2026)" />
                                </td>

                                <td>
                                    <select @bind="act.Points" class="table-select">
                                        <option value="10">10 б (Участие)</option>
                                        <option value="20">20 б (Активность)</option>
                                        <option value="30">30 б (Инициатива)</option>
                                        <option value="40">40 б (Помощь)</option>
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @* Интерактивная кнопка, которая будет добавлять новые строчки в таблицу *@
                <button class="btn-outline add-row-btn" @onclick="AddLevel1Row">
                    [ + Добавить мероприятие в Уровень 1 ]
                </button>
                <!-- --- БЛОК: МОЯ ЛИЧНАЯ ПОБЕДА НА ЭТОМ УРОВНЕ (УРОВЕНЬ 1) --- -->
                <div class="victory-block">
                    <h6 class="victory-title">Моя личная победа на этом уровне:</h6>

                    <div class="victory-list">
                        @* Пункт 1 *@
                        <label class="victory-item">
                            <input type="checkbox" class="victory-check" />
                            <span class="victory-text">Я выбрал(а) минимум 1 активность, которая мне реально понравилась.</span>
                        </label>

                        @* Пункт 2 *@
                        <label class="victory-item">
                            <input type="checkbox" class="victory-check" />
                            <span class="victory-text">Я посетил(а) мероприятие без принуждения (хотя бы 1 раз).</span>
                        </label>

                        @* Свободная линия 1 *@
                        <label class="victory-item">
                            <input type="checkbox" class="victory-check" />
                            <input type="text" class="line-input" placeholder="Нажмите, чтобы вписать свою победу..." />
                        </label>

                        @* Свободная линия 2 *@
                        <label class="victory-item">
                            <input type="checkbox" class="victory-check" />
                            <input type="text" class="line-input" />
                        </label>

                        @* Свободная линия 3 *@
                        <label class="victory-item">
                            <input type="checkbox" class="victory-check" />
                            <input type="text" class="line-input" />
                        </label>
                    </div>
                </div>

                


                <!-- --- БЛОК: УРОВЕНЬ 2. ДЛЯ СЕМЬИ И ДРУЗЕЙ --- -->
                <div class="start-block">
                    <h5 class="level-title">УРОВЕНЬ 2. ДЛЯ СЕМЬИ И ДРУЗЕЙ</h5>
                    <p class="section-subtitle">Проектирование совместных шагов с близкими, родными и окружением:</p>

                    <table class="ml-table">
                        <thead>
                            <tr>
                                <th style="width: 35%">Что планируем (мероприятие/действие)</th>
                                <th style="width: 35%">Как осуществляем (первый шаг)</th>
                                <th style="width: 15%">Дата выполнения</th>
                                <th style="width: 15%">Баллы</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Level2Activities != null)
                            {
                                @foreach (var act in Level2Activities)
                                {
                                    <tr>
                                        <td><input type="text" @bind="act.What" class="table-input" placeholder="Например: Помощь по дому" /></td>
                                        <td><input type="text" @bind="act.How" class="table-input" placeholder="Например: Составить график уборки" /></td>
                                        <td>
                                            <input type="text"
                                                   @bind="act.Date"
                                                   class="table-input date-input"
                                                   placeholder="ДД.ММ.ГГГГ"
                                                   maxlength="10"
                                                   pattern="\d{2}\.\d{2}\.\d{4}"
                                                   title="Введите дату в формате ДД.ММ.ГГГГ (например, 13.06.2026)" />
                                        </td>


                                        <td>
                                            <select @bind="act.Points" class="table-select">
                                                <option value="10">10 б</option>
                                                <option value="20">20 б</option>
                                                <option value="30">30 б</option>
                                                <option value="40">40 б</option>
                                            </select>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <button class="btn-outline add-row-btn" @onclick="AddLevel2Row">
                        [ + Добавить мероприятие в Уровень 2 ]
                    </button>
                    <!-- --- БЛОК: МОЯ ЛИЧНАЯ ПОБЕДА НА ЭТОМ УРОВНЕ --- -->
                    <div class="victory-block">
                        <h6 class="victory-title">Моя личная победа на этом уровне:</h6>

                        <div class="victory-list">
                            @* Строка 1: Специфическая цель со встроенным вводом цифры *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <span class="victory-text">
                                    Я посетил(а)
                                    <input type="text" class="inline-number-input" placeholder="___" />
                                    мероприятий в компании со своими родителями
                                </span>
                            </label>

                            @* Строка 2: Пустая строка с линией под чекбокс *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <input type="text" class="line-input" placeholder="Нажмите, чтобы вписать свою победу..." />
                            </label>

                            @* Строка 3: Пустая строка с линией под чекбокс *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <input type="text" class="line-input" />
                            </label>

                            @* Строка 4: Пустая строка с линией под чекбокс *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <input type="text" class="line-input" />
                            </label>
                        </div>
                    </div>

                </div>

                <!-- --- БЛОК: УРОВЕНЬ 3. ДЛЯ МИРА (ПРОЕКТ / ДОБРОЕ ДЕЛО) --- -->
                <div class="start-block">
                    <h5 class="level-title">УРОВЕНЬ 3. ДЛЯ МИРА (ПРОЕКТ / ДОБРОЕ ДЕЛО)</h5>
                    <p class="section-subtitle">Проектирование пользы для окружающего мира, школы, района или общества:</p>

                    <table class="ml-table">
                        <thead>
                            <tr>
                                <th style="width: 35%">What планируем (мероприятие/действие)</th>
                                <th style="width: 35%">Как осуществляем (первый шаг)</th>
                                <th style="width: 15%">Дата выполнения</th>
                                <th style="width: 15%">Баллы</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Level3Activities != null)
                            {
                                @foreach (var act in Level3Activities)
                                {
                                    <tr>
                                        <td><input type="text" @bind="act.What" class="table-input" placeholder="Например: Субботник во дворе" /></td>
                                        <td><input type="text" @bind="act.How" class="table-input" placeholder="Например: Собрать соседей" /></td>
                                        <td>
                                            <input type="text"
                                                   @bind="act.Date"
                                                   @bind:event="onchange"
                                                   @onkeypress="BlockNonDigits"
                                                   @oninput="(e) => InsertDotsOnFly(e, act)"
                                                   class="table-input"
                                                   placeholder="ДД.ММ.ГГГГ"
                                                   maxlength="10" />
                                        </td>


                                        <td>
                                            <select @bind="act.Points" class="table-select">
                                                <option value="10">10 б</option>
                                                <option value="20">20 б</option>
                                                <option value="30">30 б</option>
                                                <option value="40">40 б</option>
                                            </select>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <button class="btn-outline add-row-btn" @onclick="AddLevel3Row">
                        [ + Добавить мероприятие в Уровень 3 ]
                    </button>
                    <!-- --- БЛОК: МОЯ ЛИЧНАЯ ПОБЕДА НА ЭТОМ УРОВНЕ (УРОВЕНЬ 3) --- -->
                    <div class="victory-block">
                        <h6 class="victory-title">Моя личная победа на этом уровне:</h6>

                        <div class="victory-list">
                            @* Пункт 1 *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <span class="victory-text">Я совершил(а) хотя бы 1 добровольческое действие.</span>
                            </label>

                            @* Пункт 2 *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <span class="victory-text">Я увидел(а) результат своей помощи (обратная связь, благодарность).</span>
                            </label>

                            @* Свободная линия 1 *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <input type="text" class="line-input" placeholder="Нажмите, чтобы вписать свою победу..." />
                            </label>

                            @* Свободная линия 2 *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <input type="text" class="line-input" />
                            </label>

                            @* Свободная линия 3 *@
                            <label class="victory-item">
                                <input type="checkbox" class="victory-check" />
                                <input type="text" class="line-input" />
                            </label>
                        </div>
                    </div>


                </div>
                <!-- --- БЛОК 5: ИТОГИ КВАРТАЛА (СТРОГО ПО ШАБЛОНУ) --- -->
                <div class="start-block" style="border-bottom: none; margin-bottom: 0; padding-bottom: 0;">
                    <h5 class="level-title">ИТОГИ КВАРТАЛА</h5>
                    <p class="section-subtitle"><b>Мой прогресс по КЛЮЧЕВЫМ ПОКАЗАТЕЛЯМ</b></p>

                    <table class="ml-table">
                        <thead>
                            <tr>
                                <th style="width: 35%">Показатель</th>
                                <th style="width: 35%">Как это у меня</th>
                                <th style="width: 30%">Результат за квартал</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* Строка 1 *@
                            <tr>
                                <td>Я выполнял(а) план</td>
                                <td><input type="text" @bind="howPlan" class="table-input" placeholder="Комментарий..." /></td>
                                <td class="radio-cell">
                                    <label class="radio-label"><input type="radio" name="res_plan" @onchange='() => resPlan = "yes"' checked /> Да</label>
                                    <label class="radio-label"><input type="radio" name="res_plan" @onchange='() => resPlan = "partially"' /> Частично</label>
                                    <label class="radio-label"><input type="radio" name="res_plan" @onchange='() => resPlan = "no"' /> Нет</label>
                                </td>
                            </tr>
                            @* Строка 2 *@
                            <tr>
                                <td>Я посещал(а) школу без пропусков</td>
                                <td><input type="text" @bind="howSchool" class="table-input" placeholder="Комментарий..." /></td>
                                <td class="radio-cell">
                                    <label class="radio-label"><input type="radio" name="res_school" @onchange='() => resSchool = "yes"' /> Да</label>
                                    <label class="radio-label"><input type="radio" name="res_school" @onchange='() => resSchool = "partially"' checked /> Частично</label>
                                    <label class="radio-label"><input type="radio" name="res_school" @onchange='() => resSchool = "no"' /> Нет</label>
                                </td>
                            </tr>
                            @* Строка 3 *@
                            <tr>
                                <td>Я не лез(ла) в конфликты</td>
                                <td><input type="text" @bind="howConflict" class="table-input" placeholder="Комментарий..." /></td>
                                <td class="radio-cell">
                                    <label class="radio-label"><input type="radio" name="res_conflict" @onchange='() => resConflict = "yes"' checked /> Да</label>
                                    <label class="radio-label"><input type="radio" name="res_conflict" @onchange='() => resConflict = "partially"' /> Частично</label>
                                    <label class="radio-label"><input type="radio" name="res_conflict" @onchange='() => resConflict = "no"' /> Нет</label>
                                </td>
                            </tr>
                            @* Строка 4 *@
                            <tr>
                                <td>Я не нарушал(а) закон</td>
                                <td><input type="text" @bind="howLaw" class="table-input" placeholder="Комментарий..." /></td>
                                <td class="radio-cell">
                                    <label class="radio-label"><input type="radio" name="res_law" @onchange='() => resLaw = "yes"' checked /> Да</label>
                                    <label class="radio-label"><input type="radio" name="res_law" @onchange='() => resLaw = "partially"' /> Частично</label>
                                    <label class="radio-label"><input type="radio" name="res_law" @onchange='() => resLaw = "no"' /> Нет</label>
                                </td>
                            </tr>
                            @* Строка 5 *@
                            <tr>
                                <td>У меня есть занятие по душе</td>
                                <td><input type="text" @bind="howHobby" class="table-input" placeholder="Комментарий..." /></td>
                                <td class="radio-cell">
                                    <label class="radio-label"><input type="radio" name="res_hobby" @onchange='() => resHobby = "yes"' checked /> Да</label>
                                    <label class="radio-label"><input type="radio" name="res_hobby" @onchange='() => resHobby = "partially"' /> Частично</label>
                                    <label class="radio-label"><input type="radio" name="res_hobby" @onchange='() => resHobby = "no"' /> Нет</label>
                                </td>
                            </tr>
                            @* Строка 6 *@
                            <tr>
                                <td>Я проводил(а) время с родителями</td>
                                <td><input type="text" @bind="howParents" class="table-input" placeholder="Комментарий..." /></td>
                                <td class="radio-cell">
                                    <label class="radio-label"><input type="radio" name="res_parents" @onchange='() => resParents = "yes"' checked /> Да</label>
                                    <label class="radio-label"><input type="radio" name="res_parents" @onchange='() => resParents = "partially"' /> Частично</label>
                                    <label class="radio-label"><input type="radio" name="res_parents" @onchange='() => resParents = "no"' /> Нет</label>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <!-- --- БЛОК 6: МОЙ ВЫХОД В «ДВИЖЕНИЕ ПЕРВЫХ» --- -->
                    <div class="movement-block" style="margin-top: 30px;">
                        <h5 class="level-title">МОЙ ВЫХОД В «ДВИЖЕНИЕ ПЕРВЫХ»</h5>
                        <p class="section-subtitle"><b>Мне больше всего откликнулось (выбери 1-3):</b></p>

                        <div class="movement-checkbox-grid">
                            <label class="start-check-label"><input type="checkbox" /> Образование и знания</label>
                            <label class="start-check-label"><input type="checkbox" /> Наука и технологии</label>
                            <label class="start-check-label"><input type="checkbox" /> Труд и свое дело</label>
                            <label class="start-check-label"><input type="checkbox" /> Культура и искусство</label>
                            <label class="start-check-label"><input type="checkbox" /> Волонтерство</label>
                            <label class="start-check-label"><input type="checkbox" /> Патриотизм</label>
                            <label class="start-check-label"><input type="checkbox" /> Спорт</label>
                            <label class="start-check-label"><input type="checkbox" /> ЗОЖ</label>
                            <label class="start-check-label"><input type="checkbox" /> Медиа</label>
                            <label class="start-check-label"><input type="checkbox" /> Экология</label>
                            <label class="start-check-label"><input type="checkbox" /> Дипломатия</label>
                            <label class="start-check-label"><input type="checkbox" /> Туризм</label>
                        </div>

                        @* Финальный следующий шаг с бланковой линией *@
                        <div class="next-step-group" style="margin-top: 25px;">
                            <label class="start-input-label"><b>Мой следующий шаг (конкретное действие на следующий квартал):</b></label>
                            <input type="text" class="line-input" style="width: 100%; margin-top: 10px;" placeholder="Нажмите, чтобы вписать действие..." />
                        </div>
                    </div>
                    <!-- --- РЕШЕНИЕ НА СЛЕДУЮЩИЙ КВАРТАЛ --- -->
                    <div class="decision-block" style="margin-top: 35px; border-top: 1px dashed #ccc; padding-top: 25px;">
                        <h5 class="level-title">РЕШЕНИЕ НА СЛЕДУЮЩИЙ КВАРТАЛ</h5>

                        <div class="victory-list" style="margin-top: 15px;">
                            <label class="victory-item">
                                <input type="radio" name="next_quarter_decision" class="victory-check" checked />
                                <span class="victory-text">Продолжаем — всё в порядке, идем дальше по тому же треку.</span>
                            </label>

                            <label class="victory-item">
