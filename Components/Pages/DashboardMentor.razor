    private void BlockNonDigits(KeyboardEventArgs e)
    {
        // Разрешаем только цифры. Если это буква - Blazor её проигнорирует
        if (!char.IsDigit(e.Key[0]) && e.Key != "Backspace" && e.Key != "Delete")
        {
            return;
        }
    }

    // Логика 2: Автоматически подставляем точки, когда набрано 2 и 5 символов
    private void InsertDotsOnFly(ChangeEventArgs e, ActivityItem act)
    {
        if (e.Value == null) return;

        string val = e.Value.ToString() ?? "";

        // Очищаем от старых точек, чтобы не дублировать
        string digits = new string(val.Where(char.IsDigit).ToArray());
        string res = "";

        if (digits.Length > 0)
            res += digits.Substring(0, Math.Min(2, digits.Length));

        if (digits.Length > 2)
            res += "." + digits.Substring(2, Math.Min(2, digits.Length - 2));

        if (digits.Length > 4)
            res += "." + digits.Substring(4, Math.Min(4, digits.Length - 4));

        act.Date = res;
    }
