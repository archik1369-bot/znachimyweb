@rendermode InteractiveServer
@page "/dashboard-coordinator"
<link rel="stylesheet" href="Components/Pages/DashboardCoordinator.razor.css" />

@inject IJSRuntime JSRuntime

<PageTitle>MentoRate – Панель Координатора</PageTitle>

<div class="coordinator-container">

    <!-- Шапка кабинета -->
    <div class="cabinet-header">
        <div class="user-info">
            <span class="user-id">ID: 001</span>
            <strong>Пользователь:</strong> @currentCoordinator.FIO (Региональный координатор — Район:
            @currentCoordinator.District)
        </div>
        <button class="btn-logout">Выйти</button>
    </div>


    <!-- Основной контент: две колонки -->
    <div class="columns-wrapper">

        <!-- ЛЕВАЯ КОЛОНКА: Реестр менторов -->
        <div class="left-column">
            <h3 class="column-title">Реестр наставников</h3>
            <p class="column-subtitle">Общий список закреплённых менторов</p>

            <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Быстрый поиск по ФИО..."
                   class="search-input">

            <!-- Контейнер списка со скроллом -->
            <div class="mentors-scroll-list">
                @foreach (var mentor in FilteredMentors)
                {
                    bool isSelected = selectedMentor != null && selectedMentor.Id == mentor.Id;
                    string cardClass = isSelected ? "mentor-card mentor-selected" : "mentor-card";
                    if (mentor.CurrentSlots >= mentor.MaxSlots) cardClass += " mentor-full";

                    <div class="@cardClass" @onclick="() => SelectMentor(mentor)" style="cursor: pointer;">
                        <strong>@mentor.FIO @(isSelected ? "[ВЫБРАН]" : "")</strong>
                        <div class="mentor-id">ID: @mentor.Id</div>

                        @if (mentor.CurrentSlots >= mentor.MaxSlots)
                        {
                            <div class="status-full">Лимит полный (@mentor.CurrentSlots из @mentor.MaxSlots)</div>
                        }
                        else if (mentor.CurrentSlots == 0)
                        {
                            <div class="status-free">● Свободен (@mentor.CurrentSlots из @mentor.MaxSlots)</div>
                        }
                        else
                        {
                            <div class="slots-badge">Доступно @(mentor.MaxSlots - mentor.CurrentSlots) слота
                                (@mentor.CurrentSlots из @mentor.MaxSlots)</div>
                            }
                        </div>
                    }
                </div>

                <!-- Сводка под списком (Вычисляется динамически) -->
                <div class="summary-block">
                    <div class="summary-row">
                        <span>Всего менторов в районе:</span> <strong>@FilteredMentors.Count</strong>
                    </div>
                    <div class="summary-row">
                        <span>Детей без пар в районе:</span> <strong
                        class="badge-danger">@FreeTeenagersInDistrict.Count</strong>
                    </div>
                    <div class="summary-row">
                        <span>Свободных слотов:</span> <strong>@FilteredMentors.Sum(m => m.MaxSlots -
                                                                                                                                                                                                                                                                                                                                                                        m.CurrentSlots)</strong>
                    </div>
                </div>
            </div>

            <!-- ПРАВАЯ КОЛОНКА: Управление распределением -->
            <div class="right-column">

                <div class="right-column-header">
                    <h2 class="main-title">Распределение и прикрепление</h2>
                    <button class="btn-secondary" @onclick="ExportToExcel">Выгрузить отчет</button>
                </div>

                @if (selectedMentor != null)
                {
                    <div class="target-mentor-banner">
                        Текущий целевой наставник: <strong>@selectedMentor.FullFIO (ID: @selectedMentor.Id)</strong>
                    </div>


                    <!-- КРАТКАЯ ИНФО О МЕНТОРЕ -->
                    <div class="info-card-block">
                        <h5 class="info-card-title">Контактные данные наставника</h5>
                        <div class="info-card-row">
                            <span class="info-card-label">Опыт в проекте:</span>
                            <strong class="info-card-value">@selectedMentor.Experience</strong>
                        </div>
                        <div class="info-card-row">
                            <span class="info-card-label">Телефон для связи:</span>
                            <strong class="info-card-value">@selectedMentor.Phone</strong>
                        </div>
                        <div class="info-card-row">
                            <span class="info-card-label">Эл. почта:</span>
                            <strong class="info-card-value">@selectedMentor.Email</strong>
                        </div>
                    </div>

                    <!-- БЛОК МОНИТОРИНГА -->
                    <div class="monitor-card-block">
                        <h5 class="monitor-card-title">Мониторинг трека пары</h5>
                        <div class="info-card-row">
                            <span class="info-card-label">Текущий этап:</span>
                            <strong class="info-card-value">@selectedMentor.RouteLevel</strong>
                        </div>
                        <div class="info-card-row">
                            <span class="info-card-label">Набрано опыта:</span>
                            <strong class="info-card-value value-xp">@selectedMentor.ExperiencePoints XP</strong>
                        </div>
                        <div class="info-card-row">
                            <span class="info-card-label">Общий процент успеха:</span>
                            <strong class="info-card-value"
                                    style="color: @(selectedMentor.SuccessRate >= 70 ? "#10b981" : "#ef4444")">@selectedMentor.SuccessRate%</strong>
                        </div>
                    </div>



                    <!-- Форма ввода данных -->
                    @if (selectedMentor.CurrentSlots < selectedMentor.MaxSlots)
                    {
                        <div class="form-group">
                            <label class="form-label" style="margin-bottom: 8px;">Шаг 1: Наставляемый подросток (Дети вашего района
                                без пар)</label>
                                <select class="form-input" @bind="selectedTeenagerId">
                                    <option value="0" hidden disabled> -- Выберите ребенка из списка --</option>
                                    @foreach (var child in FreeTeenagersInDistrict)
                                    {
                                        <option value="@child.Id">@child.FIO (ID: @child.Id)</option>
                                    }
                                </select>
                            </div>

                            <button class="btn-primary" @onclick="AttachTeenager">Прикрепить к наставнику</button>

                        }
                else
                        {
                            <div class="pair-row row-empty"
                                 style="border: 1px solid #fee2e2; background: #fef2f2; color: #dc2626; margin-bottom: 35px; font-weight: bold;">
                                ⚠️ У данного наставника заполнены все доступные слоты! Прикрепление невозможно.
                            </div>
                        }

                        <!-- Список текущих пар наставника -->
                        <div class="current-pairs-block">
                            <h4 class="pairs-title">Текущие подопечные наставника (@selectedMentor.CurrentSlots из
                                @selectedMentor.MaxSlots)</h4>

                                <div class="pairs-list">
                                    @{
                                        int slotIndex = 1;
                                        foreach (var p in selectedMentor.AssignedTeenagers)
                                        {
                                            <div class="pair-row row-active">
                                                <span><strong>@slotIndex. @p.FIO</strong> (ID: @p.Id)</span>
                                                <div style="display: flex; align-items: center; gap: 10px;">
                                                    <span class="pair-document" style="background: #ecfdf5; color: #15803d;">Активен</span>
                                                    <button @onclick="() => DetachTeenager(p)" title="Открепить подростка"
                                                            style="background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5; border-radius: 4px; padding: 2px 6px; font-size: 11px; cursor: pointer; font-weight: bold;">❌</button>
                                                </div>
                                            </div>
                                            slotIndex++;

                                        }
                                        for (int i = selectedMentor.CurrentSlots; i < selectedMentor.MaxSlots; i++)
                                        {
                                            <div class="pair-row row-empty">
                                                @slotIndex. [ Свободный слот под распределение ]
                                            </div>
                                            slotIndex++;
                                        }
                                    }
                                </div>
                            </div>
                        }
            else
                        {
                            <div style="text-align: center; color: #94a3b8; margin-top: 120px; font-size: 15px;">
                                👈 Выберите наставника из реестра слева, чтобы управлять распределением и просмотреть сводку.
                            </div>
                        }

                    </div>
                </div>

                <!-- Подвал страницы -->
                <div class="cabinet-footer">
                    [значимый взрослый] • Панель управления распределением пар • 2026
                </div>
            </div>


@code {
    private class Coordinator
    {
        public int Id { get; set; }
        public string FIO { get; set; } = "";
        public string District { get; set; } = "";
    }

    private Coordinator currentCoordinator = new Coordinator
    {
        Id = 1,
        FIO = "Смирнова О.В.",
        District = "Октябрьский"
    };

    private class Teenager
    {
        public int Id { get; set; }
        public string FIO { get; set; } = "";
        public string District { get; set; } = "";
    }

    private class Mentor
    {
        public int Id { get; set; }
        public string FIO { get; set; } = "";
        public string FullFIO { get; set; } = ""; // Полное ФИО
        public string District { get; set; } = "";
        public int CurrentSlots => AssignedTeenagers.Count;
        public int MaxSlots { get; set; } = 3;
        public string Experience { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Email { get; set; } = ""; // Электронная почта

        public string RouteLevel { get; set; } = "Уровень 1: Я для себя";
        public int ExperiencePoints { get; set; } = 0;
        public int SuccessRate { get; set; } = 0;

        public List<Teenager> AssignedTeenagers { get; set; } = new();
    }

    private List<Mentor> allMentors = new();
    private List<Teenager> allTeenagers = new();

    private Mentor? selectedMentor;
    private int selectedTeenagerId = 0;
    private string searchQuery = "";

    protected override void OnInitialized()
    {
        allTeenagers = new List<Teenager>
        {
            new Teenager { Id = 884, FIO = "Подросток 1", District = "Октябрьский" },
            new Teenager { Id = 885, FIO = "Макаров Данил", District = "Октябрьский" },
            new Teenager { Id = 886, FIO = "Соколова Анна", District = "Октябрьский" },
            new Teenager { Id = 887, FIO = "Тихонов Иван", District = "Октябрьский" },
            new Teenager { Id = 901, FIO = "Кущ Никита", District = "Ленинский" },
            new Teenager { Id = 902, FIO = "Petrova Kira", District = "Кировский" }
        };

        allMentors = new List<Mentor>
        {
           new Mentor {
                Id = 542, FIO = "Петров А.В.", FullFIO = "Петров Алексей Владимирович", District = "Октябрьский", MaxSlots = 3,
                Experience = "1.5 года (1 выпускник)", Phone = "+7 (999) 123-45-67", Email = "petrov_av@mentorate.ru",
                RouteLevel = "Уровень 2: Для семьи и друзей", ExperiencePoints = 140, SuccessRate = 75,
                AssignedTeenagers = new List<Teenager> { allTeenagers[0] }
            },
            new Mentor {
                Id = 543, FIO = "Сидоров К.М.", FullFIO = "Сидоров Константин Михайлович", District = "Октябрьский", MaxSlots = 3,
                Experience = "Новичок (прошел обучение)", Phone = "+7 (999) 765-43-21", Email = "sidorov_km@mentorate.ru",
                RouteLevel = "Уровень 1: Я для себя", ExperiencePoints = 20, SuccessRate = 12
            },
            new Mentor {
                Id = 541, FIO = "Иванов П.С.", FullFIO = "Иванов Петр Сергеевич", District = "Октябрьский", MaxSlots = 3,
                Experience = "3 года (4 выпускника)", Phone = "+7 (900) 111-22-33", Email = "ivanov_ps@mentorate.ru",
                RouteLevel = "Уровень 3: Я для мира", ExperiencePoints = 320, SuccessRate = 95,
                // Забиваем ему все 3 слота реальными детьми из базы
                AssignedTeenagers = new List<Teenager> {
                    new Teenager { Id = 777, FIO = "Старый Подопечный", District = "Октябрьский" },
                    allTeenagers[2],
                    allTeenagers[3]
                }
            },
            new Mentor {
                Id = 544, FIO = "Алексеева М.Д.", FullFIO = "Алексеева Марина Дмитриевна", District = "Октябрьский", MaxSlots = 3,
                Experience = "6 месяцев", Phone = "+7 (950) 444-55-66", Email = "alekseeva_md@mentorate.ru",
                RouteLevel = "Уровень 1: Я для себя", ExperiencePoints = 50, SuccessRate = 38
            },
            new Mentor {
                Id = 545, FIO = "Кузнецов Д.С.", FullFIO = "Кузнецов Дмитрий Сергеевич", District = "Октябрьский", MaxSlots = 3,
                Experience = "Новичок", Phone = "+7 (919) 333-22-11", Email = "kuznetsov_ds@mentorate.ru",
                RouteLevel = "Уровень 1: Я для себя", ExperiencePoints = 0, SuccessRate = 0
            },
            new Mentor {
                Id = 546, FIO = "Васильев Н.А.", FullFIO = "Васильев Николай Алексеевич", District = "Октябрьский", MaxSlots = 3,
                Experience = "1 год", Phone = "+7 (904) 555-66-77", Email = "vasiliev_na@mentorate.ru",
                RouteLevel = "Уровень 2: Для семьи и друзей", ExperiencePoints = 110, SuccessRate = 60
            },
            new Mentor {
                Id = 999, FIO = "Харламов И.Ю.", FullFIO = "Харламов Игорь Юрьевич", District = "Ленинский", MaxSlots = 3,
                Experience = "2 года", Phone = "+7 (912) 000-11-22", Email = "kharlamov_iy@mentorate.ru",
                RouteLevel = "Уровень 1: Я для себя", ExperiencePoints = 30, SuccessRate = 15
            }
        };

        selectedMentor = FilteredMentors.FirstOrDefault(m => m.Id == 542);
    }

    private List<Mentor> FilteredMentors => allMentors
        .Where(m => m.District == currentCoordinator.District)
        .Where(m => string.IsNullOrWhiteSpace(searchQuery) || m.FIO.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private List<Teenager> FreeTeenagersInDistrict
    {
        get
        {
            var busyTeenagerIds = allMentors.SelectMany(m => m.AssignedTeenagers).Select(t => t.Id).ToList();
            return allTeenagers
                .Where(t => t.District == currentCoordinator.District && !busyTeenagerIds.Contains(t.Id))
                .ToList();
        }
    }

    private void SelectMentor(Mentor mentor)
    {
        selectedMentor = mentor;
        selectedTeenagerId = 0;
    }

    private async Task AttachTeenager()
    {
        if (selectedMentor == null || selectedTeenagerId == 0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Пожалуйста, выберите подростка из списка!");
            return;
        }

        var teenager = allTeenagers.FirstOrDefault(t => t.Id == selectedTeenagerId);
        if (teenager != null)
        {
            selectedMentor.AssignedTeenagers.Add(teenager);
            selectedTeenagerId = 0;
            await JSRuntime.InvokeVoidAsync("alert", $"Успешно! {teenager.FIO} закреплен.");
        }
    }
    private async Task DetachTeenager(Teenager teenager)
    {
        if (selectedMentor != null)
        {
            selectedMentor.AssignedTeenagers.Remove(teenager);
            await JSRuntime.InvokeVoidAsync("alert", $"Подросток {teenager.FIO} успешно откреплен от наставника.");
        }
    }

    private async Task ExportToExcel()
    {
        string reportPreview = $"Формирование Excel-отчета по району '{currentCoordinator.District}':\n\n";
        foreach (var m in FilteredMentors)
        {
            reportPreview += $"• {m.FIO} | Прогресс: {m.RouteLevel} ({m.ExperiencePoints} XP, Успех: {m.SuccessRate}%)\n";
        }
        await JSRuntime.InvokeVoidAsync("alert", reportPreview);
    }
}
