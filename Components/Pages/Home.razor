@rendermode InteractiveServer
@page "/"
@inject NavigationManager Navigation

<PageTitle>MentoRate — Главная</PageTitle>

<div class="landing-container">

    @* --- ШАПКА САЙТА (HEADER) --- *@
    <header class="site-header">
        <div class="logo">[значимый взрослый]</div>
        <div class="search-box">
            <input type="text" placeholder="Поиск наставника..." />
            <button>Найти</button>
        </div>
    </header>

    @* --- НАВИГАЦИЯ (NAVBAR) --- *@
    <nav class="site-nav">
        <div class="nav-links">
            <a href="/" class="active">Главная</a>
            <a href="#">О проекте</a>
            <a href="#">Цифровой трек</a>
            <a href="#">Магазин наград</a>
            <a href="#">Инструкции</a>
        </div>
        @* Маленькая и неприметная кнопка входа сбоку, как просили в правках *@
        <button class="btn-lk-top" @onclick="GoToLogin">Войти</button>
    </nav>

    @* --- ОСНОВНОЙ КОНТЕНТ (ИДЕТ СПЛОШНЫМИ СЛАЙДАМИ СВЕРХУ ВНИЗ) --- *@
    <main class="landing-main">

        @* СЛАЙД 1: Главный лозунг (Презентация) *@
        <section class="hero-block border-box">
            <h2>ПРОКАЧАЙ СВОИ НАВЫКИ И НАЙДИ ЕДИНОМЫШЛЕННИКОВ</h2>
            <p class="subtitle">Интерактивная платформа для совместной работы наставников и участников.</p>
            <p class="description">Развивайтесь вместе, фиксируйте достижения и открывайте новые возможности.</p>
        </section>

        @* СЛАЙД 2: Масштаб платформы в рамке *@
        <section class="stats-banner border-box">
            <h3>МАСШТАБ ПЛАТФОРМЫ</h3>
            <p class="stats-geo"> Мы находимся в 89 регионах РФ</p>

            <div class="stats-grid">
                <div class="stats-item">
                    <span class="stats-number">1 240</span>
                    <span class="stats-label">всего активных наставников</span>
                </div>
                <div class="stats-item">
                    <span class="stats-number">3 450</span>
                    <span class="stats-label">всего участников программы</span>
                </div>
            </div>
        </section>

        @* СЛАЙД 3: Ценности и возможности *@
        <section class="features-section">
            <h3 class="section-title">ЦЕННОСТЬ И ВОЗМОЖНОСТИ ПЛАТФОРМЫ</h3>

            <div class="features-grid">
                <div class="feature-card border-box">
                    <h5>Наставникам и Подросткам</h5>
                    <ul>
                        <li>Наставник заполняет маршрутный лист вместе со своим учеником.</li>
                        <li>Подросток видит контакты куратора и личную траекторию.</li>
                        <li>Система защищена от накруток.</li>
                    </ul>
                </div>

                <div class="feature-card border-box">
                    <h5>Баллы и Магазин наград</h5>
                    <ul>
                        <li>Получайте очки опыта за инициативу, активность и помощь другим.</li>
                        <li>Баланс кошелька отображается в профиле участника.</li>
                        <li>Обменивайте баллы на мерч (стаканы, худи, спецкурсы).</li>
                    </ul>
                </div>
            </div>
        </section>

    </main>

    @* --- ПОДВАЛ (FOOTER) --- *@
    <footer class="site-footer">
        <p>MentoRate v1.0 | Единая среда социализации Движения Первых | Техподдержка | 2026</p>
    </footer>

</div>


@* --- СТИЛИ СТРАНИЦЫ --- *@
<style>
    .landing-container {
        font-family: Arial, sans-serif;
        max-width: 1000px; /* Сделали чуть уже для более аккуратного вида презентации */
        margin: 0 auto;
        padding: 20px;
        color: #000;
    }

    .border-box {
        border: 1px solid #ccc;
        padding: 40px 30px; /* Увеличили внутренние отступы как на слайдах */
        background: #fff;
        margin-bottom: 30px; /* Отступы между слайдами вниз */
    }

    /* Шапка */
    .site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .logo {
        font-size: 24px;
        font-weight: bold;
    }

    .search-box input {
        padding: 8px 12px;
        border: 1px solid #ccc;
        width: 200px;
    }

    .search-box button {
        padding: 8px 16px;
        background: #e0e0e0;
        border: 1px solid #ccc;
        cursor: pointer;
    }

    /* Навигация */
    .site-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #ccc;
        padding: 12px 20px;
        margin-bottom: 40px;
        background: #fff;
    }

    .nav-links a {
        margin-right: 20px;
        text-decoration: none;
        color: #000;
        font-weight: bold;
        font-size: 14px;
    }

        .nav-links a.active {
            text-decoration: underline;
        }

    /* Та самая маленькая неприметная кнопка сбоку */
    .btn-lk-top {
        background: #000;
        color: #fff;
        padding: 6px 18px;
        border: none;
        cursor: pointer;
        font-weight: bold;
        font-size: 13px;
        text-transform: uppercase;
    }

    /* Одноколоночный контент */
    .landing-main {
        display: flex;
        flex-direction: column;
    }

    /* Слайд 1: Прокачай навыки */
    .hero-block {
        text-align: center;
    }

        .hero-block h2 {
            font-size: 26px;
            margin-top: 0;
            margin-bottom: 20px;
            letter-spacing: 0.5px;
        }

    .subtitle {
        font-weight: bold;
        font-size: 16px;
        margin-bottom: 15px;
    }

    .description {
        color: #555;
        font-size: 14px;
    }

    /* Слайд 2: Статистика */
    .stats-banner h3 {
        font-size: 20px;
        margin-top: 0;
        margin-bottom: 15px;
    }

    .stats-geo {
        font-size: 15px;
        font-weight: bold;
        margin-bottom: 30px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .stats-item {
        border-left: 3px solid #000;
        padding-left: 20px;
    }

    .stats-number {
        font-size: 36px;
        font-weight: 900;
        display: block;
        margin-bottom: 5px;
    }

    .stats-label {
        font-size: 14px;
        color: #555;
    }

    /* Слайд 3: Возможности */
    .features-section {
        margin-bottom: 50px;
    }

    .section-title {
        font-size: 18px;
        font-weight: bold;
        border-bottom: 2px solid #000;
        padding-bottom: 10px;
        margin-bottom: 25px;
    }

    .features-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .feature-card h5 {
        font-size: 16px;
        margin-top: 0;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .feature-card ul {
        padding-left: 20px;
        margin: 0;
    }

    .feature-card li {
        margin-bottom: 10px;
        font-size: 14px;
        color: #333;
    }

    /* Подвал */
    .site-footer {
        text-align: center;
        border-top: 1px solid #ccc;
        padding-top: 20px;
        font-size: 13px;
        color: #666;
    }
</style>

@code {
    private void GoToLogin()
    {
        // Пока временно перекидываем в кабинет наставника
        Navigation.NavigateTo("/Dashboard-mentor");
    }
}

    
            