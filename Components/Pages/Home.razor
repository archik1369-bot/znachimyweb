@code {
    // Переключение режимов: true = Вход, false = Регистрация
    private bool isLoginMode = true;
    private string authMessage = "";

    // Поля для Входа
    private string loginUsername = "";
    private string loginPassword = "";

    // Поля для Регистрации
    private string regUsername = "";
    private string regPassword = "";
    private string regRole = "student";

    private void ToggleMode()
    {
        isLoginMode = !isLoginMode;
        authMessage = ""; // Очищаем сообщения при переключении
    }

    private void HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(loginUsername) || string.IsNullOrWhiteSpace(loginPassword))
        {
            authMessage = " Заполните все поля!";
            return;
        }

        // В будущем тут будет реальная проверка по базе данных
        authMessage = $" Успешный вход для {loginUsername}!";
    }

    private void HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(regUsername) || string.IsNullOrWhiteSpace(regPassword))
        {
            authMessage = "Заполните поля регистрации!";
            return;
        }

        authMessage = $" Профиль {regUsername} ({regRole}) создан!";
    }
}

