@page "/"

<PageTitle>MentoRate — Главная</PageTitle>

<div class="landing-container">

    @* --- ШАПКА САЙТА (HEADER) --- *@
    <header class="site-header">
        <div class="logo">[значимый взрослый]</div>
        <div class="search-box">
            <input type="text" placeholder="Поиск наставника..." />
            <button>Найти</button>
        </div>
    </header>

    @* --- НАВИГАЦИЯ (NAVBAR) --- *@
    <nav class="site-nav">
        <div class="nav-links">
            <a href="/" class="active">Главная</a>
            <a href="#">О проекте</a>
            <a href="#">Цифровой трек</a>
            <a href="#">Магазин наград</a>
            <a href="#">Инструкции</a>
        </div>
        <button class="btn-lk">Личный кабинет</button>
    </nav>

    @* --- ОСНОВНОЙ КОНТЕНТ (ДВЕ КОЛОНКИ) --- *@
    <main class="main-grid">

        @* ЛЕВАЯ КОЛОНКА:  Масштаб *@
        <section class="content-left">

            @* БЛОК 1: Масштаб платформы (теперь сверху и в рамке) *@
            <div class="stats-banner border-box">
                <h3>МАСШТАБ ПЛАТФОРМЫ</h3>
                <p class="stats-geo"> Мы находимся в 89 регионах РФ</p>

                <div class="stats-grid">
                    <div class="stats-item">
                        <span class="stats-number">1 240</span>
                        <span class="stats-label">всего активных наставников</span>
                    </div>
                    <div class="stats-item">
                        <span class="stats-number">3 450</span>
                        <span class="stats-label">всего участников программы</span>
                    </div>
                </div>
            </div>

            @* БЛОК 2: Прокачай навыки  *@
            <div class="hero-block border-box">
                <h2>ПРОКАЧАЙ СВОИ НАВЫКИ И НАЙДИ ЕДИНОМЫШЛЕННИКОВ</h2>
                <p class="subtitle">Интерактивная платформа для совместной работы наставников и участников.</p>
                <p class="description">Развивайтесь вместе, фиксируйте достижения и открывайте новые возможности.</p>
            </div>

        </section>

        @* ПРАВАЯ КОЛОНКА: Вход и Инфо *@
        <aside class="content-right">
            <div class="info-card auth-card">
                @if (isLoginMode)
                {
                    <h4>01. ВХОД В СИСТЕМУ</h4>
                    <div class="auth-form">
                        <div class="form-group">
                            <label>Логин или Email</label>
                            <input type="text" @bind="loginUsername" placeholder="Введите логин..." />
                        </div>
                        <div class="form-group">
                            <label>Пароль</label>
                            <input type="password" @bind="loginPassword" placeholder="Введите пароль..." />
                        </div>
                        <button class="btn-auth" @onclick="HandleLogin">Войти</button>
                        <p class="auth-toggle">Нет аккаунта? <span @onclick="ToggleMode">Регистрация</span></p>
                    </div>
                }
                else
                {
                    <h4>01. РЕГИСТРАЦИЯ</h4>
                    <div class="auth-form">
                        <div class="form-group">
                            <label>Имя пользователя</label>
                            <input type="text" @bind="regUsername" placeholder="Придумайте логин..." />
                        </div>
                        <div class="form-group">
                            <label>Пароль</label>
                            <input type="password" @bind="regPassword" placeholder="Придумайте пароль..." />
                        </div>
                        <div class="form-group">
                            <label>Кто вы?</label>
                            <select @bind="regRole">
                                <option value="student">Учётник (Подросток)</option>
                                <option value="mentor">Наставник</option>
                            </select>
                        </div>
                        <button class="btn-auth btn-reg" @onclick="HandleRegister">Создать профиль</button>
                        <p class="auth-toggle">Уже есть аккаунт? <span @onclick="ToggleMode">Войти</span></p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(authMessage))
                {
                    <div class="auth-message">@authMessage</div>
                }
            </div>


            <div class="info-card">
                <h4>02. ЦИФРОВОЙ ТРЕК</h4>
                <p>Проходите уровни развития в удобном диджитал-формате. Пошагово фиксируйте свои успехи вместе с куратором на интерактивной карте.</p>
            </div>
        </aside>

    </main>

    @* --- БЛОК: ЦЕННОСТЬ И ВОЗМОЖНОСТИ --- *@
    <section class="features-section">
        <h3>ЦЕННОСТЬ И ВОЗМОЖНОСТИ ПЛАТФОРМЫ</h3>

        <div class="features-grid">
            <div class="feature-card">
                <h5>Наставникам и Подросткам</h5>
                <ul>
                    <li>Наставник заполняет маршрутный лист вместе со своим учеником.</li>
                    <li>Подросток видит контакты куратора и личную траекторию.</li>
                    <li>Система защищена от накруток.</li>
                </ul>
            </div>

            <div class="feature-card">
                <h5>Баллы и Магазин наград</h5>
                <ul>
                    <li>Получайте очки опыта за инициативу, активность и помощь другим.</li>
                    <li>Баланс кошелька отображается в профиле участника.</li>
                    <li>Обменивайте баллы на мерч (стаканы, худи, спецкурсы).</li>
                </ul>
            </div>
        </div>
    </section>

    @* --- ПОДВАЛ (FOOTER) --- *@
    <footer class="site-footer">
        <p>MentoRate v1.0 | Единая среда социализации Движения Первых | Техподдержка | 2026</p>
    </footer>

</div>

